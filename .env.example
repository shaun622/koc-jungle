# Optional — only required to enable cloud sync (Stage 2.4).
# Without these the app runs in local-only mode (the default).
#
# Get these from your Supabase project's Settings → API page.
# Anon key is the public client key (safe to ship in the bundle).

# VITE_SUPABASE_URL=https://<your-project>.supabase.co
# VITE_SUPABASE_ANON_KEY=ey...your-anon-key

# Optional — RevenueCat (Stage 2.5, subscription paywall).
# Native builds only — the web PWA's paywall is informational and
# directs users to the iOS / Android app to subscribe.
# Get these from RevenueCat dashboard -> Project -> API Keys -> Public.
# VITE_REVENUECAT_PUBLIC_API_KEY_IOS=appl_...
# VITE_REVENUECAT_PUBLIC_API_KEY_ANDROID=goog_...
